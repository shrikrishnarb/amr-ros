<?xml version="1.0"?>
<!--
  butler_test.sdf - minimal Gazebo Harmonic test world for the butler robot.

  World system plugins are declared explicitly (Harmonic loads defaults from
  server.config, but being explicit keeps the world self-contained):
    - Physics          : dynamics
    - UserCommands     : required by `ros_gz_sim create` (/world/.../create service)
    - SceneBroadcaster : GUI / scene state
    - Sensors (ogre2)  : gpu_lidar + rgbd_camera rendering. ogre2 is verified to
                         work with LIBGL_ALWAYS_SOFTWARE=1 on GPU-less VMs
                         (see CLAUDE.md "Verified rendering config").
  The Contact system is not needed: no contact sensors in this stack.
-->
<sdf version="1.8">
  <world name="butler_test">

    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>50 50</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>50 50</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.7 0.7 0.7 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- A few box obstacles at lidar height, spread around the spawn point -->
    <model name="box_a">
      <static>true</static>
      <pose>3.0 0.0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1 1 1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1 1 1</size></box></geometry>
          <material>
            <ambient>0.8 0.2 0.2 1</ambient>
            <diffuse>0.8 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="box_b">
      <static>true</static>
      <pose>-2.0 2.5 0.4 0 0 0.6</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.8 0.8 0.8</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.8 0.8 0.8</size></box></geometry>
          <material>
            <ambient>0.2 0.4 0.8 1</ambient>
            <diffuse>0.2 0.4 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="box_c">
      <static>true</static>
      <pose>1.5 -3.0 0.3 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.6 1.6 0.6</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.6 1.6 0.6</size></box></geometry>
          <material>
            <ambient>0.2 0.7 0.3 1</ambient>
            <diffuse>0.2 0.7 0.3 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="box_d">
      <static>true</static>
      <pose>-3.5 -2.0 0.75 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.5 0.5 1.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.5 0.5 1.5</size></box></geometry>
          <material>
            <ambient>0.9 0.7 0.1 1</ambient>
            <diffuse>0.9 0.7 0.1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
