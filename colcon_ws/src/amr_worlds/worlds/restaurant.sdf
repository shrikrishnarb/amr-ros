<?xml version="1.0"?>
<!--
  restaurant.sdf - Gazebo Harmonic (gz-sim 8) restaurant world for the butler
  robot. Primitive geometry only (boxes / cylinders): no meshes, no Fuel
  downloads, VM/software-rendering friendly (see CLAUDE.md).

  Footprint: 16 m x 10 m (x in [-8, 8], y in [-5, 5]), walls 2.5 m high.
  All tables stand on four cylinder legs so the butler lidar (scan plane at
  z = 0.25 m) detects the legs, not the (invisible-to-lidar) table tops.
  Aisles between table/chair envelopes are >= 1.4 m for the 0.70 m robot.
  The charging_dock pad is VISUAL-ONLY (no collision): it sits below the lidar
  plane and must not bump the wheels when the robot drives onto it.

  NAMED LOCATIONS (approx x, y) - basis for semantic_map.yaml (next phase):
    table_1          (-2.5,  2.2)
    table_2          ( 1.0,  2.2)
    table_3          ( 4.5,  2.2)
    table_4          (-2.5, -2.2)
    table_5          ( 1.0, -2.2)
    table_6          ( 4.5, -2.2)
    kitchen_counter  (-5.5, -2.3)   pickup along its west face (kitchen side)
    bar_counter      ( 5.0,  4.5)   along the north wall, service face south
    charging_dock    ( 7.0, -4.3)   SE corner; robot spawns at (6.3, -4.0)
    kitchen doorway  (-5.0,  0.0)   1.4 m wide opening in the divider wall
    main entrance    ( 3.2, -5.0)   2.0 m wide opening in the south wall
  Unnamed obstacles: kitchen_shelf (-7.6, 2.5), plant_pot_1 (-4.3, 4.0),
    plant_pot_2 (0.5, -4.4), divider (3.2, -3.4).

  World system plugins: same set as amr_butler_description butler_test.sdf
  (Physics, UserCommands, SceneBroadcaster, Sensors/ogre2 - the verified
  software-rendering engine).
-->
<sdf version="1.8">
  <world name="restaurant">

    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- bright, evenly lit scene so the RGB-D camera sees well indoors -->
    <scene>
      <ambient>0.7 0.7 0.7 1</ambient>
      <background>0.6 0.75 0.85 1</background>
      <shadows>true</shadows>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.3 0.2 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>40 40</size></plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>40 40</size></plane>
          </geometry>
          <material>
            <ambient>0.75 0.72 0.65 1</ambient>
            <diffuse>0.75 0.72 0.65 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- building shell + kitchen divider wall (doorway 1.4 m wide) -->
    <model name="walls">
      <static>true</static>
      <link name="wall_north">
        <pose>0.0 5.0 1.25 0 0 0</pose>
        <collision name="wall_col"><pose>0 0 0 0 0 0</pose><geometry><box><size>16.3 0.15 2.5</size></box></geometry></collision>
        <visual name="wall_vis"><pose>0 0 0 0 0 0</pose><geometry><box><size>16.3 0.15 2.5</size></box></geometry><material><ambient>0.85 0.8 0.75 1</ambient><diffuse>0.85 0.8 0.75 1</diffuse></material></visual>
      </link>
      <link name="wall_south_west">
        <pose>-2.975 -5.0 1.25 0 0 0</pose>
        <collision name="wall_col"><pose>0 0 0 0 0 0</pose><geometry><box><size>10.35 0.15 2.5</size></box></geometry></collision>
        <visual name="wall_vis"><pose>0 0 0 0 0 0</pose><geometry><box><size>10.35 0.15 2.5</size></box></geometry><material><ambient>0.85 0.8 0.75 1</ambient><diffuse>0.85 0.8 0.75 1</diffuse></material></visual>
      </link>
      <link name="wall_south_east">
        <pose>6.175 -5.0 1.25 0 0 0</pose>
        <collision name="wall_col"><pose>0 0 0 0 0 0</pose><geometry><box><size>3.95 0.15 2.5</size></box></geometry></collision>
        <visual name="wall_vis"><pose>0 0 0 0 0 0</pose><geometry><box><size>3.95 0.15 2.5</size></box></geometry><material><ambient>0.85 0.8 0.75 1</ambient><diffuse>0.85 0.8 0.75 1</diffuse></material></visual>
      </link>
      <link name="wall_east">
        <pose>8.0 0.0 1.25 0 0 0</pose>
        <collision name="wall_col"><pose>0 0 0 0 0 0</pose><geometry><box><size>0.15 10.0 2.5</size></box></geometry></collision>
        <visual name="wall_vis"><pose>0 0 0 0 0 0</pose><geometry><box><size>0.15 10.0 2.5</size></box></geometry><material><ambient>0.85 0.8 0.75 1</ambient><diffuse>0.85 0.8 0.75 1</diffuse></material></visual>
      </link>
      <link name="wall_west">
        <pose>-8.0 0.0 1.25 0 0 0</pose>
        <collision name="wall_col"><pose>0 0 0 0 0 0</pose><geometry><box><size>0.15 10.0 2.5</size></box></geometry></collision>
        <visual name="wall_vis"><pose>0 0 0 0 0 0</pose><geometry><box><size>0.15 10.0 2.5</size></box></geometry><material><ambient>0.85 0.8 0.75 1</ambient><diffuse>0.85 0.8 0.75 1</diffuse></material></visual>
      </link>
      <link name="kitchen_wall_north">
        <pose>-5.0 2.85 1.25 0 0 0</pose>
        <collision name="wall_col"><pose>0 0 0 0 0 0</pose><geometry><box><size>0.15 4.3 2.5</size></box></geometry></collision>
        <visual name="wall_vis"><pose>0 0 0 0 0 0</pose><geometry><box><size>0.15 4.3 2.5</size></box></geometry><material><ambient>0.85 0.8 0.75 1</ambient><diffuse>0.85 0.8 0.75 1</diffuse></material></visual>
      </link>
      <link name="kitchen_wall_south">
        <pose>-5.0 -2.85 1.25 0 0 0</pose>
        <collision name="wall_col"><pose>0 0 0 0 0 0</pose><geometry><box><size>0.15 4.3 2.5</size></box></geometry></collision>
        <visual name="wall_vis"><pose>0 0 0 0 0 0</pose><geometry><box><size>0.15 4.3 2.5</size></box></geometry><material><ambient>0.85 0.8 0.75 1</ambient><diffuse>0.85 0.8 0.75 1</diffuse></material></visual>
      </link>
    </model>

    <!-- dining area: 6 tables on four cylinder legs each;
         tables 1 and 4 seat four, the rest seat two -->
    <model name="table_1">
      <static>true</static>
      <pose>-2.5 2.2 0 0 0 0</pose>
      <link name="table">
        <collision name="top_col"><pose>0 0 0.725 0 0 0</pose><geometry><box><size>0.8 0.8 0.05</size></box></geometry></collision>
        <visual name="top_vis"><pose>0 0 0.725 0 0 0</pose><geometry><box><size>0.8 0.8 0.05</size></box></geometry><material><ambient>0.6 0.4 0.25 1</ambient><diffuse>0.6 0.4 0.25 1</diffuse></material></visual>
        <collision name="leg_1_col"><pose>-0.32 -0.32 0.35 0 0 0</pose><geometry><cylinder><radius>0.035</radius><length>0.7</length></cylinder></geometry></collision>
        <visual name="leg_1_vis"><pose>-0.32 -0.32 0.35 0 0 0</pose><geometry><cylinder><radius>0.035</radius><length>0.7</length></cylinder></geometry><material><ambient>0.25 0.25 0.28 1</ambient><diffuse>0.25 0.25 0.28 1</diffuse></material></visual>
        <collision name="leg_2_col"><pose>-0.32 0.32 0.35 0 0 0</pose><geometry><cylinder><radius>0.035</radius><length>0.7</length></cylinder></geometry></collision>
        <visual name="leg_2_vis"><pose>-0.32 0.32 0.35 0 0 0</pose><geometry><cylinder><radius>0.035</radius><length>0.7</length></cylinder></geometry><material><ambient>0.25 0.25 0.28 1</ambient><diffuse>0.25 0.25 0.28 1</diffuse></material></visual>
        <collision name="leg_3_col"><pose>0.32 -0.32 0.35 0 0 0</pose><geometry><cylinder><radius>0.035</radius><length>0.7</length></cylinder></geometry></collision>
        <visual name="leg_3_vis"><pose>0.32 -0.32 0.35 0 0 0</pose><geometry><cylinder><radius>0.035</radius><length>0.7</length></cylinder></geometry><material><ambient>0.25 0.25 0.28 1</ambient><diffuse>0.25 0.25 0.28 1</diffuse></material></visual>
        <collision name="leg_4_col"><pose>0.32 0.32 0.35 0 0 0</pose><geometry><cylinder><radius>0.035</radius><length>0.7</length></cylinder></geometry></collision>
        <visual name="leg_4_vis"><pose>0.32 0.32 0.35 0 0 0</pose><geometry><cylinder><radius>0.035</radius><length>0.7</length></cylinder></geometry><material><ambient>0.25 0.25 0.28 1</ambient><diffuse>0.25 0.25 0.28 1</diffuse></material></visual>
