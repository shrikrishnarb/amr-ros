        <visual name="leg_2_vis"><pose>-0.16 0.16 0.21 0 0 0</pose><geometry><cylinder><radius>0.02</radius><length>0.42</length></cylinder></geometry><material><ambient>0.25 0.25 0.28 1</ambient><diffuse>0.25 0.25 0.28 1</diffuse></material></visual>
        <collision name="leg_3_col"><pose>0.16 -0.16 0.21 0 0 0</pose><geometry><cylinder><radius>0.02</radius><length>0.42</length></cylinder></geometry></collision>
